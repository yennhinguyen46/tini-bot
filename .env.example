# Telegram Bot Token (lấy từ @BotFather trên Telegram)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# OpenAI API Key (lấy từ https://platform.openai.com/api-keys)
OPENAI_API_KEY=your_openai_api_key_here

# Tên và tính cách của bot (tuỳ chỉnh)
BOT_NAME=Tí Nị
BOT_PERSONALITY=Bạn là Tí Nị, một trợ lý AI thân thiện, dễ thương và hay giúp đỡ. Bạn trả lời bằng tiếng Việt, giọng điệu nhẹ nhàng, vui vẻ và thân thiện như một người bạn tốt.

# Giới hạn lịch sử hội thoại (số tin nhắn lưu lại cho mỗi người dùng)
MAX_HISTORY=20
